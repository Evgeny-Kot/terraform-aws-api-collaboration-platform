aws_region               = "us-east-1"
project_name             = "api-collaboration-platform"
environment              = "dev"
owner                    = "platform-engineering"
domain_name              = "api-dev.example.com"
health_check_path        = "/"
hosted_zone_id           = "Z1234567890ABC"
vpc_cidr                 = "10.20.0.0/16"
availability_zones       = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs      = ["10.20.0.0/24", "10.20.1.0/24"]
private_app_subnet_cidrs = ["10.20.10.0/24", "10.20.11.0/24"]
private_db_subnet_cidrs  = ["10.20.20.0/24", "10.20.21.0/24"]
container_image          = "public.ecr.aws/docker/library/nginx:1.27-alpine"
app_cpu                  = 512
app_memory               = 1024
desired_count            = 2
min_capacity             = 2
max_capacity             = 4
db_instance_class        = "db.t4g.medium"
db_allocated_storage     = 100
db_max_allocated_storage = 300
db_name                  = "apicollab"
db_username              = "platform_admin"
alarm_email_endpoints    = ["platform-alerts@example.com"]
log_retention_in_days    = 30
single_nat_gateway       = true

aws_region               = "us-east-1"
project_name             = "api-collaboration-platform"
environment              = "stage"
owner                    = "platform-engineering"
domain_name              = "api-stage.example.com"
health_check_path        = "/health"
hosted_zone_id           = "Z1234567890ABC"
vpc_cidr                 = "10.30.0.0/16"
availability_zones       = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs      = ["10.30.0.0/24", "10.30.1.0/24"]
private_app_subnet_cidrs = ["10.30.10.0/24", "10.30.11.0/24"]
private_db_subnet_cidrs  = ["10.30.20.0/24", "10.30.21.0/24"]
container_image          = "123456789012.dkr.ecr.us-east-1.amazonaws.com/api-collab:stage"
app_cpu                  = 1024
app_memory               = 2048
desired_count            = 2
min_capacity             = 2
max_capacity             = 6
db_instance_class        = "db.t4g.large"
db_allocated_storage     = 150
db_max_allocated_storage = 500
db_name                  = "apicollab"
db_username              = "platform_admin"
alarm_email_endpoints    = ["platform-alerts@example.com"]
log_retention_in_days    = 60
single_nat_gateway       = false

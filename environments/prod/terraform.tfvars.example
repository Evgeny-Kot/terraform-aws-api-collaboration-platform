aws_region               = "us-east-1"
project_name             = "api-collaboration-platform"
environment              = "prod"
owner                    = "platform-engineering"
domain_name              = "api.example.com"
health_check_path        = "/health"
hosted_zone_id           = "Z1234567890ABC"
vpc_cidr                 = "10.40.0.0/16"
availability_zones       = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnet_cidrs      = ["10.40.0.0/24", "10.40.1.0/24", "10.40.2.0/24"]
private_app_subnet_cidrs = ["10.40.10.0/24", "10.40.11.0/24", "10.40.12.0/24"]
private_db_subnet_cidrs  = ["10.40.20.0/24", "10.40.21.0/24", "10.40.22.0/24"]
container_image          = "123456789012.dkr.ecr.us-east-1.amazonaws.com/api-collab:prod"
app_cpu                  = 2048
app_memory               = 4096
desired_count            = 4
min_capacity             = 4
max_capacity             = 10
db_instance_class        = "db.r6g.large"
db_allocated_storage     = 200
db_max_allocated_storage = 1000
db_name                  = "apicollab"
db_username              = "platform_admin"
alarm_email_endpoints    = ["platform-alerts@example.com", "oncall@example.com"]
log_retention_in_days    = 90
single_nat_gateway       = false
